# Core project context
PROJECT_NAME=finops-dashboard
ENVIRONMENT=dev

# Cloud/provider target
PRIMARY_PROVIDER=gcp
PRIMARY_BILLING_SCOPE=example-billing-scope
AWS_ACCOUNT_ID=000000000000
AZURE_SUBSCRIPTION_ID=00000000-0000-0000-0000-000000000000

# FinOps metadata
COST_OWNER_TAG_KEY=owner
COST_ENV_TAG_KEY=environment
COST_SERVICE_TAG_KEY=service

# Observability endpoints
PROMETHEUS_URL=http://localhost:9090
GRAFANA_URL=http://localhost:3000

# Script/runtime behavior
LOG_LEVEL=INFO
OUTPUT_DIR=./tmp/output
